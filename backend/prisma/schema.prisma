// CalPro — Prisma schema for separate Express backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FoodTag {
  breakfast
  lunch
  dinner
  snack
  junk
}

enum QuantityMode {
  grams
  piece
  ml
  serving
}

model User {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  supabaseId    String?        @unique
  email         String?        @unique
  name          String?
  image         String?
  anonymousId   String?        @unique
  settings      Settings?
  foodLogs      FoodLog[]
  customFoods   CustomFood[]
  publicFoods   PublicFood[]
  mealTemplates MealTemplate[]
  waterLogs     WaterLog[]
}

model Settings {
  id                 String  @id @default(cuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyCalorieTarget Int     @default(2000)
  dailyProteinTarget Int     @default(120)
  trackCarbsFat      Boolean @default(false)
  twitterHandle      String?
  dailyWaterTarget   Int     @default(2500) // ml
}

model FoodLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  calories         Int
  protein          Float
  carbs            Float?
  fat              Float?
  date             String   // "YYYY-MM-DD" — KEEP AS STRING (streak/summary rely on local-date equality)
  createdAt        DateTime @default(now())
  tag              FoodTag
  consumedWeightG  Float?

  @@index([userId, date])
  @@index([userId, createdAt])
}

model CustomFood {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  category        String
  caloriesPer100g Float
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  defaultQty      Float
  quantityMode    QuantityMode
  gramsPerPiece   Float?
  mlPerServing    Float?
  emoji           String?
  barcode         String? // for barcode-cached items

  @@index([userId])
}

enum FoodSource {
  IFCT
  USDA
  OFF
  VERIFIED_USER
  AI_GENERATED
}

model Food {
  id              String       @id @default(cuid())
  name            String
  category        String
  caloriesPer100g Float
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  defaultQty      Float
  quantityMode    QuantityMode
  gramsPerPiece   Float?
  mlPerServing    Float?
  emoji           String?
  barcode         String?      @unique
  source          FoodSource   @default(IFCT)
  sourceRef       String?
  isIndian        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  aliases         FoodAlias[]
  portions        FoodPortion[]
  scanFeedbacks   ScanFeedback[]

  @@index([name])
  @@index([isIndian])
}

model FoodAlias {
  id        String         @id @default(cuid())
  foodId    String
  food      Food           @relation(fields: [foodId], references: [id], onDelete: Cascade)
  alias     String
  language  String         @default("en")
  region    String?

  @@index([alias])
  @@unique([foodId, alias])
}

model FoodPortion {
  id        String         @id @default(cuid())
  foodId    String
  food      Food           @relation(fields: [foodId], references: [id], onDelete: Cascade)
  label     String
  unit      String
  grams     Float
  sortOrder Int            @default(0)
  isDefault Boolean        @default(false)

  @@index([foodId])
}

model ScanCache {
  id        String   @id @default(cuid())
  userId    String?
  imageHash String
  result    Json
  hitCount  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, imageHash])
  @@index([imageHash])
}

model ScanFeedback {
  id              String          @id @default(cuid())
  userId          String
  foodId          String?
  food            Food?           @relation(fields: [foodId], references: [id], onDelete: SetNull)
  originalName    String
  correctedName   String
  originalGrams   Float
  correctedGrams  Float
  applied         Boolean         @default(false)
  createdAt       DateTime        @default(now())

  @@index([userId])
  @@index([originalName])
  @@index([correctedName])
}

model MealTemplate {                  // Roadmap 3.3 "My Meals"
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  tag       FoodTag
  items     MealTemplateItem[]
  createdAt DateTime           @default(now())
}

model MealTemplateItem {
  id           String       @id @default(cuid())
  userId       String
  templateId   String
  template     MealTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name         String
  quantity     Float
  quantityMode QuantityMode
  displayQty   Float
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  emoji        String?

  @@index([userId])
}

model PublicFood {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String
  calories    Float    // per servingSize
  protein     Float    // per servingSize
  carbs       Float    // per servingSize
  fat         Float    // per servingSize
  servingSize Float    // e.g. 50 (grams)
  servingUnit String   // "g" | "ml" | "piece"
  emoji       String?
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([userId])
}

model WaterLog {                       // Roadmap 3.8
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   String // "YYYY-MM-DD"
  amount Int    // ml

  @@unique([userId, date])
}
